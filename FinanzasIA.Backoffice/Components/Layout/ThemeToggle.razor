@rendermode InteractiveServer
@implements IDisposable
@inject FinanzasIA.Backoffice.Services.ThemeService Theme

<button type="button" class="theme-toggle theme-toggle-icon" @onclick="ToggleThemeAsync" title="@(Theme.IsDark ? "Modo claro" : "Modo oscuro")" aria-label="Cambiar tema">
	<span aria-hidden="true">@(Theme.IsDark ? "☀️" : "🌙")</span>
</button>

@code {
	protected override void OnInitialized()
	{
		Theme.OnChange += OnThemeChanged;
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			await Theme.InitializeAsync();
		}
	}

	private async Task ToggleThemeAsync() => await Theme.ToggleAsync();

	private void OnThemeChanged() => InvokeAsync(StateHasChanged);

	public void Dispose() => Theme.OnChange -= OnThemeChanged;
}
