@rendermode InteractiveServer
@inject IJSRuntime JSRuntime

<button type="button" class="theme-toggle theme-toggle-icon" @onclick="ToggleThemeAsync" title="@(_isDark ? "Modo claro" : "Modo oscuro")" aria-label="Cambiar tema">
    <span aria-hidden="true">@(_isDark ? "☀️" : "🌙")</span>
</button>

@code {
    private bool _isDark;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _isDark = await JSRuntime.InvokeAsync<bool>("finanzasTheme.initialize");
        StateHasChanged();
    }

    private async Task ToggleThemeAsync()
    {
        _isDark = await JSRuntime.InvokeAsync<bool>("finanzasTheme.toggle");
    }
}
