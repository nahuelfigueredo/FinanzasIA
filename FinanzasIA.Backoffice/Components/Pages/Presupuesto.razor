@page "/presupuesto"
@rendermode InteractiveServer
@inject FinanzasApiClient ApiClient
@inject IJSRuntime JSRuntime

<PageTitle>Presupuesto</PageTitle>

<div class="page-heading">
    <span class="page-icon" aria-hidden="true">🎯</span>
    <div>
        <h1>Presupuesto</h1>
        <p>Controlá cuánto gastaste este mes y cuánto queda disponible.</p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert alert-warning" role="alert">@_errorMessage</div>
}
else if (_isLoading)
{
    <div class="report-loading">
        <div class="spinner-border text-primary" role="status"></div>
        <span>Cargando presupuesto...</span>
    </div>
}
else
{
    <div class="row g-4 mb-4">
        <div class="col-xl-7">
            <div class="budget-hero @BudgetStatusClass">
                <div>
                    <span class="budget-status">@BudgetStatusText</span>
                    <h2>@SpentThisMonth.ToString("C")</h2>
                    <p>gastado de @_preferences.MonthlyBudget.ToString("C") este mes</p>
                </div>
                <div class="budget-available">
                    <span>Disponible</span>
                    <strong>@RemainingBudget.ToString("C")</strong>
                </div>
                <div class="budget-progress">
                    <div style="width:@BudgetPercentage%"></div>
                </div>
            </div>
        </div>

        <div class="col-xl-5">
            <div class="dashboard-panel h-100">
                <h4 class="mb-3"><span class="section-icon" aria-hidden="true">⚙️</span> Ajustar límite mensual</h4>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <InputNumber class="form-control" @bind-Value="_preferences.MonthlyBudget" />
                    <button class="btn btn-primary" type="button" @onclick="SaveBudgetAsync">Guardar</button>
                </div>
                <p class="text-secondary mt-3 mb-0">Este valor se guarda en este navegador.</p>
            </div>
        </div>
    </div>

    <div class="dashboard-panel">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
            <div>
                <h4 class="mb-1"><span class="section-icon" aria-hidden="true">🏷️</span> Gasto por categoría</h4>
                <p class="text-secondary mb-0">Top categorías del mes actual.</p>
            </div>
            <span class="report-pill">@CurrentMonthMovements.Count movimientos del mes</span>
        </div>

        @if (CategoryExpenses.Count == 0)
        {
            <div class="empty-state">
                <div>📭</div>
                <strong>Sin gastos este mes</strong>
                <span>Cuando registres egresos, vas a ver el avance por categoría.</span>
                <a class="empty-action" href="movimientos">➕ Registrar egreso</a>
            </div>
        }
        else
        {
            <div class="category-budget-list">
                @foreach (var category in CategoryExpenses)
                {
                    <div class="category-budget-item">
                        <div class="chart-label">
                            <span>@category.Name</span>
                            <strong>@category.Amount.ToString("C")</strong>
                        </div>
                        <div class="chart-track">
                            <div class="chart-bar category" style="width:@GetCategoryPercentage(category.Amount)%"></div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    private readonly PreferenceModel _preferences = new();
    private IReadOnlyCollection<MovimientoDto> _movimientos = [];
    private bool _isLoading = true;
    private string? _errorMessage;

    private IReadOnlyCollection<MovimientoDto> CurrentMonthMovements => _movimientos
        .Where(m => m.Fecha.Year == DateTime.Today.Year && m.Fecha.Month == DateTime.Today.Month)
        .ToArray();

    private decimal SpentThisMonth => CurrentMonthMovements
        .Where(m => m.Tipo == TipoMovimiento.Egreso)
        .Sum(m => m.Monto);

    private decimal RemainingBudget => _preferences.MonthlyBudget - SpentThisMonth;
    private decimal BudgetPercentage => _preferences.MonthlyBudget <= 0 ? 0 : Math.Clamp(SpentThisMonth / _preferences.MonthlyBudget * 100, 0, 100);

    private string BudgetStatusClass => BudgetPercentage switch
    {
        >= 100 => "danger",
        >= 80 => "warning",
        _ => "success"
    };

    private string BudgetStatusText => BudgetPercentage switch
    {
        >= 100 => "Presupuesto superado",
        >= 80 => "Cerca del límite",
        _ => "Vas bien"
    };

    private IReadOnlyCollection<CategoryExpense> CategoryExpenses => CurrentMonthMovements
        .Where(m => m.Tipo == TipoMovimiento.Egreso)
        .GroupBy(m => m.CategoriaNombre)
        .Select(g => new CategoryExpense(g.Key, g.Sum(m => m.Monto)))
        .OrderByDescending(g => g.Amount)
        .ToArray();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            var preferences = await JSRuntime.InvokeAsync<PreferenceModel>("finanzasPreferences.get");
            _preferences.UserName = preferences.UserName;
            _preferences.Currency = preferences.Currency;
            _preferences.MonthlyBudget = preferences.MonthlyBudget;
            _preferences.FiscalDay = preferences.FiscalDay;
            _preferences.ShowDemoHint = preferences.ShowDemoHint;

            _movimientos = await ApiClient.GetMovimientosAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task SaveBudgetAsync()
    {
        await JSRuntime.InvokeAsync<PreferenceModel>("finanzasPreferences.set", _preferences);
        await JSRuntime.InvokeVoidAsync("finanzasUi.toast", "Presupuesto actualizado.", "success");
    }

    private decimal GetCategoryPercentage(decimal amount)
    {
        var max = CategoryExpenses.Count == 0 ? 0 : CategoryExpenses.Max(c => c.Amount);
        return max <= 0 ? 0 : Math.Clamp(amount / max * 100, 6, 100);
    }

    private sealed record CategoryExpense(string Name, decimal Amount);

    private sealed class PreferenceModel
    {
        public string UserName { get; set; } = "Usuario";
        public string Currency { get; set; } = "ARS";
        public decimal MonthlyBudget { get; set; } = 100000;
        public int FiscalDay { get; set; } = 1;
        public bool ShowDemoHint { get; set; } = true;
    }
}
