@page "/configuracion"
@rendermode InteractiveServer
@inject IJSRuntime JSRuntime
@inject FinanzasApiClient ApiClient
@inject FinanzasIA.Backoffice.Services.ThemeService Theme
@implements IDisposable

<PageTitle>Configuración</PageTitle>

<div class="page-heading">
    <span class="page-icon" aria-hidden="true">⚙️</span>
    <div>
        <h1>Configuración</h1>
        <p>Personalizá la experiencia de Finanzas IA en este dispositivo.</p>
    </div>
</div>

@if (_isLoading)
{
    <div class="skeleton-grid" aria-label="Cargando configuración">
        <div class="skeleton skeleton-panel"></div>
        <div class="skeleton skeleton-panel"></div>
    </div>
}
else
{
    <div class="row g-4">
        <div class="col-xl-7">
            <div class="dashboard-panel">
                <h4 class="mb-3"><span class="section-icon" aria-hidden="true">👤</span> Preferencias</h4>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Nombre</label>
                        <InputText class="form-control" @bind-Value="_preferences.UserName" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Moneda</label>
                        <InputSelect class="form-select" @bind-Value="_preferences.Currency">
                            <option value="ARS">ARS - Peso argentino</option>
                            <option value="USD">USD - Dólar</option>
                            <option value="EUR">EUR - Euro</option>
                            <option value="UYU">UYU - Peso uruguayo</option>
                        </InputSelect>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Presupuesto mensual</label>
                        <InputNumber class="form-control" @bind-Value="_preferences.MonthlyBudget" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Día de inicio del mes fiscal</label>
                        <InputNumber class="form-control" @bind-Value="_preferences.FiscalDay" />
                    </div>
                    <div class="col-12">
                        <div class="form-check form-switch">
                            <InputCheckbox class="form-check-input" @bind-Value="_preferences.ShowDemoHint" />
                            <label class="form-check-label">Mostrar sugerencias para cargar datos demo</label>
                        </div>
                    </div>
                </div>

                <button class="btn btn-primary mt-4" type="button" @onclick="SaveAsync">💾 Guardar configuración</button>
            </div>

            <div class="dashboard-panel mt-4">
                <h4 class="mb-1"><span class="section-icon" aria-hidden="true">🎨</span> Apariencia</h4>
                <p class="text-muted small mb-3">Elegí el tema de toda la aplicación. Se aplica al instante y se recuerda en futuras sesiones.</p>
                <div class="theme-selector">
                    <button type="button" class="theme-option @(Theme.IsDark ? "" : "activa")" @onclick="@(() => Theme.SetThemeAsync("light"))">
                        <span class="theme-option-icono" aria-hidden="true">☀️</span>
                        <strong>Modo Claro</strong>
                        <span class="text-muted small">Blancos suaves y grises claros</span>
                    </button>
                    <button type="button" class="theme-option @(Theme.IsDark ? "activa" : "")" @onclick="@(() => Theme.SetThemeAsync("dark"))">
                        <span class="theme-option-icono" aria-hidden="true">🌙</span>
                        <strong>Modo Oscuro</strong>
                        <span class="text-muted small">Oscuro moderno, sin negro absoluto</span>
                    </button>
                </div>
            </div>
        </div>

        <div class="col-xl-5">
            <div class="dashboard-panel h-100">
                <h4 class="mb-3"><span class="section-icon" aria-hidden="true">✨</span> Vista previa</h4>
                <div class="settings-preview">
                    <div class="page-icon">👋</div>
                    <h3>Hola, @_preferences.UserName</h3>
                    <p>Tu moneda principal es <strong>@_preferences.Currency</strong>.</p>
                    <p>Presupuesto mensual: <strong>@_preferences.MonthlyBudget.ToString("C")</strong></p>
                    <p class="mb-0">Mes fiscal desde el día <strong>@_preferences.FiscalDay</strong>.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="dashboard-panel mt-4">
        <h4 class="mb-1"><span class="section-icon" aria-hidden="true">💬</span> WhatsApp</h4>
        <p class="text-muted small mb-3">Vinculá tu número para registrar movimientos enviando mensajes por WhatsApp.</p>

        @if (!string.IsNullOrEmpty(_whatsappMensaje))
        {
            <div class="alert @(_whatsappExito ? "alert-success" : "alert-warning") py-2">@_whatsappMensaje</div>
        }

        <div class="row g-2 align-items-end mb-3">
            <div class="col-12 col-md-4">
                <label class="form-label">Número de teléfono</label>
                <input class="form-control" placeholder="Ej: 5492211234567" @bind="_nuevoNumero" />
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label">Nombre (opcional)</label>
                <input class="form-control" placeholder="Ej: Mi celular" @bind="_nuevoNombre" />
            </div>
            <div class="col-12 col-md-4">
                <button class="btn btn-primary" type="button" disabled="@_procesandoWhatsapp" @onclick="VincularNumeroAsync">
                    🔗 Vincular
                </button>
            </div>
        </div>

        @if (_cargandoNumeros)
        {
            <p class="text-muted small mb-0">Cargando números vinculados...</p>
        }
        else if (_numeros.Count == 0)
        {
            <p class="text-muted small mb-0">Todavía no tenés números vinculados.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Número</th>
                            <th>Nombre</th>
                            <th>Última conexión</th>
                            <th>Fecha de alta</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var n in _numeros)
                        {
                            <tr>
                                <td class="text-nowrap">@n.NumeroTelefono</td>
                                <td>@(n.Nombre ?? "—")</td>
                                <td class="text-nowrap">@(n.FechaUltimoUso?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "—")</td>
                                <td class="text-nowrap">@n.FechaAlta.ToLocalTime().ToString("dd/MM/yyyy")</td>
                                <td class="text-nowrap text-end">
                                    <button class="btn btn-sm btn-outline-danger" type="button" disabled="@_procesandoWhatsapp"
                                            @onclick="() => EliminarNumeroAsync(n.Id)">🗑️ Eliminar</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="dashboard-panel mt-4">
        <h4 class="mb-1"><span class="section-icon" aria-hidden="true">🔌</span> Integraciones</h4>
        <p class="text-muted small mb-3">Servicios externos conectados a Finanzas IA.</p>

        <div class="row g-3">
            <div class="col-12 col-md-6 col-xl-3">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <strong>💬 WhatsApp</strong>
                            <span class="badge @(_numeros.Count > 0 ? "bg-success" : "bg-secondary")">
                                @(_numeros.Count > 0 ? "Conectado" : "Sin vincular")
                            </span>
                        </div>
                        <p class="text-muted small mb-0">Registrá movimientos y consultá tus finanzas por mensaje. Administrá tus números en la sección de arriba.</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-xl-3">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <strong>🤖 OpenAI</strong>
                            <span class="badge bg-success">Activo</span>
                        </div>
                        <p class="text-muted small mb-0">Motor de IA del chat, análisis y clasificación automática. Se configura en el servidor.</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-xl-3">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <strong>📧 Email</strong>
                            <span class="badge bg-secondary">Próximamente</span>
                        </div>
                        <p class="text-muted small mb-0">Resúmenes y alertas por correo electrónico.</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-xl-3">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <strong>✨ Más integraciones</strong>
                            <span class="badge bg-secondary">Próximamente</span>
                        </div>
                        <p class="text-muted small mb-0">Bancos, billeteras virtuales y otros servicios se sumarán en el futuro.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private PreferenceModel _preferences = new();
    private bool _isLoading = true;

    private IReadOnlyCollection<UsuarioWhatsappDto> _numeros = [];
    private bool _cargandoNumeros = true;
    private bool _procesandoWhatsapp;
    private string _nuevoNumero = string.Empty;
    private string _nuevoNombre = string.Empty;
    private string _whatsappMensaje = string.Empty;
    private bool _whatsappExito;

    protected override void OnInitialized()
    {
        Theme.OnChange += OnThemeChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await Theme.InitializeAsync();
        _preferences = await JSRuntime.InvokeAsync<PreferenceModel>("finanzasPreferences.get");
        _isLoading = false;
        StateHasChanged();

        await CargarNumerosAsync();
        StateHasChanged();
    }

    private void OnThemeChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Theme.OnChange -= OnThemeChanged;

    private async Task CargarNumerosAsync()
    {
        try
        {
            _numeros = await ApiClient.GetNumerosWhatsappAsync();
        }
        catch
        {
            _numeros = [];
        }
        finally
        {
            _cargandoNumeros = false;
        }
    }

    private async Task VincularNumeroAsync()
    {
        if (string.IsNullOrWhiteSpace(_nuevoNumero))
        {
            MostrarMensajeWhatsapp("Ingresá un número de teléfono.", false);
            return;
        }

        _procesandoWhatsapp = true;
        try
        {
            var resultado = await ApiClient.VincularNumeroWhatsappAsync(new VincularNumeroDto
            {
                NumeroTelefono = _nuevoNumero.Trim(),
                Nombre = string.IsNullOrWhiteSpace(_nuevoNombre) ? null : _nuevoNombre.Trim()
            });

            MostrarMensajeWhatsapp(resultado.Mensaje, resultado.Exito);
            if (resultado.Exito)
            {
                _nuevoNumero = string.Empty;
                _nuevoNombre = string.Empty;
                await CargarNumerosAsync();
            }
        }
        catch
        {
            MostrarMensajeWhatsapp("No se pudo vincular el número. Intentá de nuevo.", false);
        }
        finally
        {
            _procesandoWhatsapp = false;
        }
    }

    private async Task EliminarNumeroAsync(int id)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "¿Desvincular este número de WhatsApp?");
        if (!confirmed)
        {
            return;
        }

        _procesandoWhatsapp = true;
        try
        {
            await ApiClient.EliminarNumeroWhatsappAsync(id);
            MostrarMensajeWhatsapp("Número eliminado.", true);
            await CargarNumerosAsync();
        }
        catch
        {
            MostrarMensajeWhatsapp("No se pudo eliminar el número.", false);
        }
        finally
        {
            _procesandoWhatsapp = false;
        }
    }

    private void MostrarMensajeWhatsapp(string mensaje, bool exito)
    {
        _whatsappMensaje = mensaje;
        _whatsappExito = exito;
    }

    private async Task SaveAsync()
    {
        _preferences.FiscalDay = Math.Clamp(_preferences.FiscalDay, 1, 28);
        _preferences.MonthlyBudget = Math.Max(0, _preferences.MonthlyBudget);
        _preferences = await JSRuntime.InvokeAsync<PreferenceModel>("finanzasPreferences.set", _preferences);
        await JSRuntime.InvokeVoidAsync("finanzasUi.toast", "Configuración guardada.", "success");
    }

    private sealed class PreferenceModel
    {
        public string UserName { get; set; } = "Usuario";
        public string Currency { get; set; } = "ARS";
        public decimal MonthlyBudget { get; set; } = 100000;
        public int FiscalDay { get; set; } = 1;
        public bool ShowDemoHint { get; set; } = true;
    }
}
