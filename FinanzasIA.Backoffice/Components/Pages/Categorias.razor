@page "/categorias"
@rendermode InteractiveServer
@inject FinanzasApiClient ApiClient
@inject IJSRuntime JSRuntime
@using System.ComponentModel.DataAnnotations

<PageTitle>Categorías</PageTitle>

<div class="cat-header">
	<div class="cat-header-text">
		<h1>Categorías</h1>
		<p>Organizá tus ingresos y egresos mediante categorías personalizadas.</p>
	</div>
	<button class="cat-new-btn" type="button" @onclick="ScrollToForm">
		<span aria-hidden="true">＋</span> Nueva categoría
	</button>
</div>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
	<div class="alert alert-danger" role="alert">@_errorMessage</div>
}
else if (!string.IsNullOrWhiteSpace(_successMessage))
{
	<div class="alert alert-success" role="alert">@_successMessage</div>
}

<div class="cat-card cat-form-card" id="categoria-form-card">
	<div class="cat-card-header">
		<span class="cat-card-icon" aria-hidden="true">✨</span>
		<h4>@(_editingId.HasValue ? "Editar categoría" : "Nueva categoría")</h4>
	</div>
	<EditForm FormName="categoria-form" Model="_form" OnValidSubmit="SaveAsync">
		<DataAnnotationsValidator />
		<ValidationSummary />
		<div class="row g-3">
			<div class="col-md-6">
				<label class="form-label">Nombre</label>
				<InputText class="form-control" placeholder="Ej: Supermercado" @bind-Value="_form.Nombre" />
			</div>
			<div class="col-md-3">
				<label class="form-label">Tipo</label>
				<InputSelect class="form-select" @bind-Value="_form.TipoMovimiento">
					@foreach (var tipo in Enum.GetValues<TipoMovimiento>())
					{
						<option value="@tipo">@tipo</option>
					}
				</InputSelect>
			</div>
			<div class="col-md-3 d-flex align-items-end">
				<button type="submit" class="btn btn-primary w-100 cat-submit-btn" disabled="@_isSaving">
					@if (_isSaving)
					{
						<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
						<span>Guardando...</span>
					}
					else
					{
						<span>@(_editingId.HasValue ? "Actualizar categoría" : "Crear categoría")</span>
					}
				</button>
			</div>
		</div>
	</EditForm>
	@if (_editingId.HasValue)
	{
		<button class="btn btn-link p-0 mt-2" @onclick="CancelEdit">Cancelar edición</button>
	}
</div>

<div class="cat-card cat-list-card">
	<div class="cat-toolbar">
		<div class="cat-toolbar-title">
			<h5>Tus categorías</h5>
			<span class="cat-count">@_filtered.Count de @_categorias.Count</span>
		</div>
		<div class="cat-toolbar-controls">
			<input class="form-control cat-search" type="search" placeholder="🔍 Buscar categoría..."
				   value="@_searchText" @oninput="OnSearchChanged" />
			<div class="cat-filter-group" role="group" aria-label="Filtrar por tipo">
				<button type="button" class="cat-filter-btn @(_filterTipo is null ? "active" : null)"
						@onclick="() => SetFilter(null)">Todas</button>
				<button type="button" class="cat-filter-btn @(_filterTipo == TipoMovimiento.Ingreso ? "active" : null)"
						@onclick="() => SetFilter(TipoMovimiento.Ingreso)">Ingresos</button>
				<button type="button" class="cat-filter-btn @(_filterTipo == TipoMovimiento.Egreso ? "active" : null)"
						@onclick="() => SetFilter(TipoMovimiento.Egreso)">Egresos</button>
			</div>
		</div>
	</div>

	@if (_isLoading)
	{
		<div class="skeleton-grid" aria-label="Cargando categorías">
			<div class="skeleton skeleton-panel"></div>
		</div>
	}
	else if (_categorias.Count == 0)
	{
		<div class="cat-empty">
			<span aria-hidden="true">🏷️</span>
			<strong>No hay categorías cargadas todavía.</strong>
			<p>Creá tu primera categoría con el formulario de arriba.</p>
		</div>
	}
	else if (_filtered.Count == 0)
	{
		<div class="cat-empty">
			<span aria-hidden="true">🔍</span>
			<strong>Sin resultados.</strong>
			<p>Probá con otro texto o cambiá el filtro.</p>
		</div>
	}
	else
	{
		<div class="table-responsive">
			<table class="table align-middle cat-table">
				<thead>
					<tr>
						<th>Nombre</th>
						<th>Tipo</th>
						<th>Uso</th>
						<th class="text-end">Acciones</th>
					</tr>
				</thead>
				<tbody>
					@foreach (var categoria in _pageItems)
					{
						<tr>
							<td>
								<span class="cat-name">
									<span class="cat-emoji" aria-hidden="true">@GetIcono(categoria.Nombre, categoria.TipoMovimiento)</span>
									@categoria.Nombre
								</span>
							</td>
							<td>
								@if (categoria.TipoMovimiento == TipoMovimiento.Ingreso)
								{
									<span class="cat-badge cat-badge-ingreso">Ingreso</span>
								}
								else
								{
									<span class="cat-badge cat-badge-egreso">Egreso</span>
								}
								@if (categoria.EsSistema)
								{
									<span class="cat-badge cat-badge-sistema" title="Categoría predeterminada del sistema">Sistema</span>
								}
								@if (!categoria.Activa)
								{
									<span class="cat-badge cat-badge-inactiva">Inactiva</span>
								}
							</td>
							<td>
								<span class="cat-uso">@GetUso(categoria.Id) movimientos</span>
							</td>
							<td class="text-end">
								<div class="cat-actions">
									<button class="cat-action-btn cat-action-edit" type="button" title="Editar categoría"
											@onclick="() => Edit(categoria)">✏️</button>
									@if (categoria.EsSistema)
									{
										<button class="cat-action-btn cat-action-delete" type="button" title="@(categoria.Activa ? "Desactivar categoría" : "Activar categoría")"
												@onclick="() => CambiarEstadoAsync(categoria)">@(categoria.Activa ? "🚫" : "✅")</button>
									}
									else
									{
										<button class="cat-action-btn cat-action-delete" type="button" title="Eliminar categoría"
												@onclick="() => DeleteAsync(categoria.Id)">🗑️</button>
									}
								</div>
							</td>
						</tr>
					}
				</tbody>
			</table>
		</div>

		@if (TotalPages > 1)
		{
			<div class="cat-pagination">
				<button type="button" class="cat-page-btn" disabled="@(_page == 1)" @onclick="() => GoToPage(_page - 1)">‹</button>
				@for (var i = 1; i <= TotalPages; i++)
				{
					var pageNumber = i;
					<button type="button" class="cat-page-btn @(pageNumber == _page ? "active" : null)"
							@onclick="() => GoToPage(pageNumber)">@pageNumber</button>
				}
				<button type="button" class="cat-page-btn" disabled="@(_page == TotalPages)" @onclick="() => GoToPage(_page + 1)">›</button>
			</div>
		}
	}
</div>

@code {
	private const int PageSize = 8;

	private readonly List<CategoriaDto> _categorias = [];
	private Dictionary<int, int> _usoPorCategoria = [];
	private CategoriaFormModel _form = new();
	private int? _editingId;
	private string? _errorMessage;
	private string? _successMessage;
	private string _searchText = string.Empty;
	private TipoMovimiento? _filterTipo;
	private int _page = 1;
	private bool _isLoading = true;
	private bool _isSaving;

	private List<CategoriaDto> _filtered =>
		_categorias
			.Where(c => _filterTipo is null || c.TipoMovimiento == _filterTipo)
			.Where(c => string.IsNullOrWhiteSpace(_searchText)
				|| c.Nombre.Contains(_searchText.Trim(), StringComparison.OrdinalIgnoreCase))
			.OrderBy(c => c.Nombre, StringComparer.OrdinalIgnoreCase)
			.ToList();

	private int TotalPages => Math.Max(1, (int)Math.Ceiling(_filtered.Count / (double)PageSize));

	private List<CategoriaDto> _pageItems =>
		_filtered.Skip((Math.Min(_page, TotalPages) - 1) * PageSize).Take(PageSize).ToList();

	protected override async Task OnInitializedAsync()
	{
		await LoadCategoriasAsync();
		_isLoading = false;
	}

	private async Task LoadCategoriasAsync()
	{
		_errorMessage = null;
		try
		{
			var categorias = await ApiClient.GetCategoriasAsync();
			_categorias.Clear();
			_categorias.AddRange(categorias);

			try
			{
				var movimientos = await ApiClient.GetMovimientosAsync();
				_usoPorCategoria = movimientos
					.GroupBy(m => m.CategoriaId)
					.ToDictionary(g => g.Key, g => g.Count());
			}
			catch
			{
				_usoPorCategoria = [];
			}
		}
		catch (Exception ex)
		{
			_errorMessage = $"No pudimos cargar tus categorías. Reintentá en unos segundos. ({ex.Message})";
		}
	}

	private int GetUso(int categoriaId) => _usoPorCategoria.GetValueOrDefault(categoriaId);

	private void OnSearchChanged(ChangeEventArgs e)
	{
		_searchText = e.Value?.ToString() ?? string.Empty;
		_page = 1;
	}

	private void SetFilter(TipoMovimiento? tipo)
	{
		_filterTipo = tipo;
		_page = 1;
	}

	private void GoToPage(int page)
	{
		_page = Math.Clamp(page, 1, TotalPages);
	}

	private void ScrollToForm()
	{
		CancelEdit();
	}

	private static string GetIcono(string nombre, TipoMovimiento tipo)
	{
		var n = nombre.ToLowerInvariant();
		if (n.Contains("carnicer") || n.Contains("super") || n.Contains("almac") || n.Contains("verduler")) return "🛒";
		if (n.Contains("celular") || n.Contains("tel")) return "📱";
		if (n.Contains("gas")) return "🔥";
		if (n.Contains("gym") || n.Contains("gimnas") || n.Contains("deporte")) return "🏋️";
		if (n.Contains("luz") || n.Contains("electric")) return "💡";
		if (n.Contains("panader") || n.Contains("pan")) return "🥖";
		if (n.Contains("salario") || n.Contains("sueldo") || n.Contains("honorario")) return "💰";
		if (n.Contains("agua")) return "💧";
		if (n.Contains("internet") || n.Contains("wifi")) return "🌐";
		if (n.Contains("alquiler") || n.Contains("casa") || n.Contains("hogar")) return "🏠";
		if (n.Contains("auto") || n.Contains("nafta") || n.Contains("combustible") || n.Contains("transporte")) return "🚗";
		if (n.Contains("salud") || n.Contains("farmacia") || n.Contains("medic")) return "💊";
		if (n.Contains("educaci") || n.Contains("curso") || n.Contains("colegio")) return "📚";
		if (n.Contains("comida") || n.Contains("restaurante") || n.Contains("delivery")) return "🍽️";
		if (n.Contains("ropa") || n.Contains("indument")) return "👕";
		if (n.Contains("viaje") || n.Contains("vacacion")) return "✈️";
		if (n.Contains("regalo")) return "🎁";
		if (n.Contains("mascota")) return "🐾";
		if (n.Contains("inversi") || n.Contains("ahorro")) return "📈";
		if (n.Contains("entretenimiento") || n.Contains("cine") || n.Contains("stream")) return "🎬";
		return tipo == TipoMovimiento.Ingreso ? "💵" : "🏷️";
	}

	private async Task SaveAsync()
	{
		_errorMessage = null;
		_successMessage = null;
		_isSaving = true;
		try
		{
			if (_editingId.HasValue)
			{
				await ApiClient.UpdateCategoriaAsync(_editingId.Value, new UpdateCategoriaDto
				{
					Nombre = _form.Nombre,
					TipoMovimiento = _form.TipoMovimiento
				});
				_successMessage = "Categoría actualizada correctamente.";
			}
			else
			{
				await ApiClient.CreateCategoriaAsync(new CreateCategoriaDto
				{
					Nombre = _form.Nombre,
					TipoMovimiento = _form.TipoMovimiento
				});
				_successMessage = "Categoría creada correctamente.";
			}

			CancelEdit();
			await LoadCategoriasAsync();
			await JSRuntime.InvokeVoidAsync("finanzasUi.toast", _successMessage, "success");
		}
		catch (Exception ex)
		{
			_errorMessage = $"No se pudo guardar la categoría. ({ex.Message})";
			await JSRuntime.InvokeVoidAsync("finanzasUi.toast", "No se pudo guardar la categoría.", "danger");
		}
		finally
		{
			_isSaving = false;
		}
	}

	private void Edit(CategoriaDto categoria)
	{
		_editingId = categoria.Id;
		_form = new CategoriaFormModel
		{
			Nombre = categoria.Nombre,
			TipoMovimiento = categoria.TipoMovimiento
		};
	}

	private async Task DeleteAsync(int id)
	{
		var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "¿Eliminar esta categoría? Esta acción no se puede deshacer.");
		if (!confirmed)
		{
			return;
		}

		_errorMessage = null;
		_successMessage = null;
		try
		{
			await ApiClient.DeleteCategoriaAsync(id);
			await LoadCategoriasAsync();
			_successMessage = "Categoría eliminada correctamente.";
			await JSRuntime.InvokeVoidAsync("finanzasUi.toast", _successMessage, "success");
		}
		catch (Exception ex)
		{
			_errorMessage = $"No se pudo eliminar la categoría. ({ex.Message})";
			await JSRuntime.InvokeVoidAsync("finanzasUi.toast", "No se pudo eliminar la categoría.", "danger");
		}
	}

	private async Task CambiarEstadoAsync(CategoriaDto categoria)
	{
		_errorMessage = null;
		_successMessage = null;
		try
		{
			await ApiClient.CambiarEstadoCategoriaAsync(categoria.Id, !categoria.Activa);
			await LoadCategoriasAsync();
			_successMessage = categoria.Activa ? "Categoría desactivada." : "Categoría activada.";
			await JSRuntime.InvokeVoidAsync("finanzasUi.toast", _successMessage, "success");
		}
		catch (Exception ex)
		{
			_errorMessage = $"No se pudo cambiar el estado de la categoría. ({ex.Message})";
			await JSRuntime.InvokeVoidAsync("finanzasUi.toast", "No se pudo cambiar el estado de la categoría.", "danger");
		}
	}

	private void CancelEdit()
	{
		_editingId = null;
		_form = new CategoriaFormModel();
	}

	private class CategoriaFormModel
	{
		[Required(ErrorMessage = "El nombre es obligatorio.")]
		[MaxLength(100, ErrorMessage = "El nombre no puede superar los 100 caracteres.")]
		public string Nombre { get; set; } = string.Empty;
		public TipoMovimiento TipoMovimiento { get; set; } = TipoMovimiento.Egreso;
	}
}
